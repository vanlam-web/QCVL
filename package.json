{
  "name": "qcvl",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "vite --host 0.0.0.0 --port 3000",
    "api:dev": "tsx server/index.ts",
    "api:build": "tsc -p tsconfig.server.json",
    "api:start": "node dist-server/index.js",
    "build": "tsc -b && vite build",
    "build:all": "npm run build && npm run api:build",
    "db:migrate": "node scripts/db-migrate.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run src scripts/*.test.mjs tests/e2e/*.test.ts",
    "test:watch": "vitest",
    "test:db": "supabase test db",
    "test:functions": "node scripts/deno-function-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "import:kiotviet-products": "node scripts/import-kiotviet-products.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:functions": "supabase functions serve api --env-file supabase/.env.local"
  },
  "dependencies": {
    "@sentry/react": "^10.63.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.23.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "supabase": "^2.108.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
