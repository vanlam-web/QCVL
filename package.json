{
  "name": "qcvl",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "vite --host 0.0.0.0 --port 3000",
    "api:dev": "tsx watch server/index.ts",
    "api:build": "tsc -p tsconfig.server.json",
    "api:start": "node dist-server/index.js",
    "build": "tsc -b && vite build",
    "build:all": "npm run build && npm run api:build",
    "build:nas": "node scripts/build-nas.mjs",
    "verify:nas-bundle": "node scripts/verify-nas-bundle.mjs",
    "verify:nas-build": "npm run build:nas && npm run verify:nas-bundle",
    "verify:local": "npm run lint && npm run typecheck && npm test && npm run build:all",
    "health:nas": "node scripts/health-nas.mjs",
    "deploy:nas": "node scripts/deploy-nas.mjs",
    "import:dev-memory-to-postgres": "tsx scripts/import-dev-memory-state-to-postgres.ts",
    "verify:sales-finance-persistence": "node scripts/verify-sales-finance-persistence.mjs",
    "smoke:nas": "node scripts/smoke-nas-ui.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:migrate:dry-run": "node scripts/db-migrate-dry-run.mjs",
    "env:status": "node scripts/env-status.mjs",
    "dev:seed-products": "node scripts/dev-seed-kiotviet-products.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run src scripts/*.test.mjs tests/e2e/*.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "import:kiotviet-products": "node scripts/import-kiotviet-products.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.63.0",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.23.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
